@model ChatbotCreateViewModel

<h2>Crear Chatbot</h2>
<form asp-action="CrearChatbot" method="post" id="chatbotForm">
    <div>
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name"></span>
    </div>
    <div>
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description"></span>
    </div>
    <div id="questions-container">
        @for (int q = 0; q < Model.Questions.Count; q++)
        {
            <div class="question-block border p-2 mb-2">
                <label>Pregunta @(q + 1)</label>
                <input name="Questions[@q].Question" class="form-control" value="@Model.Questions[q].Question" />
                <label>Respuestas posibles</label>
                @for (int a = 0; a < 5; a++)
                {
                    <input name="Questions[@q].Answers[@a]" class="form-control mb-1" value="@(Model.Questions[q].Answers.Count > a ? Model.Questions[q].Answers[a] : "")" placeholder="Respuesta @(a+1)" />
                }
                <button type="button" class="btn btn-danger btn-sm mt-2" onclick="removeQuestion(this)">Quitar pregunta</button>
            </div>
        }
    </div>
    <button type="button" class="btn btn-secondary" onclick="addQuestion()">Agregar otra pregunta</button>
    <button type="submit" class="btn btn-primary">Guardar</button>
</form>

@section Scripts {
    <script>
        function addQuestion() {
            var container = document.getElementById('questions-container');
            var qIndex = container.children.length;
            var block = document.createElement('div');
            block.className = 'question-block border p-2 mb-2';
            block.innerHTML = `
                <label>Pregunta ${qIndex + 1}</label>
                <input name="Questions[${qIndex}].Question" class="form-control" />
                <label>Respuestas posibles</label>
                ${[0,1,2,3,4].map(a => `<input name="Questions[${qIndex}].Answers[${a}]" class="form-control mb-1" placeholder="Respuesta ${a+1}" />`).join('')}
                <button type="button" class="btn btn-danger btn-sm mt-2" onclick="removeQuestion(this)">Quitar pregunta</button>
            `;
            container.appendChild(block);
        }
        function removeQuestion(btn) {
            btn.parentElement.remove();
            // Opcional: reindexar los nombres de los campos si quieres mantener el orden
        }
    </script>
}